# Block direct HTTP access to dotfiles, env, composer, artisan, etc.
# Only matches against the file *name*, so /something/.env and /.env are both blocked.
<FilesMatch "^\.|^composer\.(json|lock)$|^package(-lock)?\.json$|^artisan$|^phpunit\.xml$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Hide the /public segment from the URL. Used when the subdomain's
    # document root points at the project root instead of public/.
    #
    # If the request path doesn't already start with public/, rewrite it
    # internally so the real file lookup happens inside public/. Everything
    # is funneled through public/, so the project's source folders
    # (app/, config/, database/, …) are effectively unreachable from the web
    # without any extra blocking rules — Apache will just 404 because the
    # rewritten path public/app/Foo.php doesn't exist.
    #
    # Note: /storage/<path> URLs work because public/storage is a symlink
    # to storage/app/public created by `php artisan storage:link`. After
    # rewriting they become public/storage/<path> → the symlinked file.
    #
    # If your host lets you set the subdomain's document root directly to
    # public/, use that instead (cPanel: Subdomains → Document Root) and
    # delete this file — faster and a tiny bit safer.

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
